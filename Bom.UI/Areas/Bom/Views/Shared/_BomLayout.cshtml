<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - ALMES ERP</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/bom/css/bom-layout.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
        <div class="container-fluid px-3">

            <div class="d-flex align-items-center">
                <a href="/Portal" class="btn btn-sm btn-portal-back me-3 fw-semibold rounded-1">
                    <i class="bi bi-arrow-left-square-fill me-1"></i> Portala Dön
                </a>
                <span class="navbar-brand m-0 h1 fs-5 fw-bold font-monospace text-info d-none d-sm-inline-block">
                    <i class="bi bi-diagram-3-fill me-1"></i>BOM
                </span>
            </div>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#almesHeaderNavbar" aria-controls="almesHeaderNavbar" aria-expanded="false" aria-label="Menüyü Aç">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="almesHeaderNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-1 text-center">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/Bom">
                            <i class="bi bi-speedometer2 me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RecipeList" ? "active" : "")" href="/Bom/RecipeList">
                            <i class="bi bi-calculator me-1"></i> Reçete Listesi
                        </a>
                    </li>
                </ul>

                <div class="text-center">
                    <span class="badge bg-secondary p-2 rounded-1 font-monospace">
                        <i class="bi bi-person-circle me-1"></i>
                        @(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Guest")
                    </span>
                </div>
            </div>

        </div>
    </nav>

    <div class="almes-main-wrapper">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </div>

    <footer class="almes-fixed-footer">
        <div class="footer-left">
            <strong>ALMES ERP</strong> — Stok Reçete Yönetim Sistemi
        </div>
        <div class="footer-right font-monospace fw-bold">
            v0.0.24
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>