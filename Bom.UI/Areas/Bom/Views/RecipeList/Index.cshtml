@model Bom.Lib.PagedBomResult

@{
    ViewData["Title"] = "Reçete Listeleri";
    Layout = "~/Areas/Bom/Views/Shared/_BomLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="/bom/css/bom-recipe-list.css">
    <style>
        .table-flat tbody tr.clickable-row:hover {
            background-color: #f1f3f5 !important;
            transition: background-color 0.15s ease-in-out;
        }
    </style>
}

<div class="erp-box">
    <div class="erp-header p-3 d-flex align-items-center justify-content-between bg-white border border-bottom-0 rounded-top-1">
        <div>
            <h5 class="fw-bold m-0 text-dark">
                <i class="bi bi-box-seam-fill me-2 text-primary"></i>
                🏭 Tanımlı Stok Kartları Listesi (Mamul / Yarı Mamul)
            </h5>
        </div>
        <div>
            <a href="/Bom/RecipeManagement" class="btn btn-sm btn-primary fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Yeni Reçete Ekle
            </a>
        </div>
    </div>

    <div class="p-3 bg-white border rounded-bottom-1 shadow-sm">
        <div class="alert alert-secondary p-2 mb-3 rounded-1 d-flex align-items-center border" role="alert">
            <i class="bi bi-info-circle-fill text-dark fs-5 me-2"></i>
            <div class="small text-dark">
                Reçetesi olan aktif Mamul ve Yarı Mamul listesidir. Detaylı üretim ağacı için satıra <strong>çift tıklayabilir</strong> veya sağdaki <strong>aksiyon butonlarını</strong> kullanabilirsiniz.
            </div>
        </div>

        <div class="p-3 mb-3 bg-light rounded-1 border">
            <form method="get" action="/Bom/RecipeList" id="searchForm" class="row g-2 align-items-center">
                <input type="hidden" name="page" value="1" />

                <div class="col-12 col-md-6">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" name="productCode" class="form-control border-start-0 ps-0" placeholder="Ürün Kodu Sorgula... (Örn: M-001)" value="@Context.Request.Query["productCode"]" />
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <select name="pageSize" class="form-select form-select-sm" onchange="document.getElementById('searchForm').submit();">
                        <!option value="10" @(ViewBag.PageSize == 10 ? "selected" : "")>10 Kayıt</!option>
                        <!option value="20" @(ViewBag.PageSize == 20 ? "selected" : "")>20 Kayıt</!option>
                        <!option value="50" @(ViewBag.PageSize == 50 ? "selected" : "")>50 Kayıt</!option>
                        <!option value="100" @(ViewBag.PageSize == 100 ? "selected" : "")>100 Kayıt</!option>
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <button type="submit" class="btn btn-dark btn-sm w-100 fw-semibold">
                        <i class="bi bi-funnel-fill me-1"></i> Query
                    </button>
                </div>

                <div class="col-12 col-md-2">
                    <a href="/Bom/RecipeList" class="btn btn-outline-secondary btn-sm w-100 fw-semibold">
                        <i class="bi bi-arrow-clockwise"></i> Temizle
                    </a>
                </div>
            </form>
        </div>

        @if (Model?.Items != null && Model.Items.Count > 0)
        {
            <div class="table-responsive border rounded-1">
                <table class="table table-sm table-flat align-middle m-0">
                    <thead>
                        <tr>
                            <th scope="col" class="py-2" style="width: 150px;">Ürün / Stok Kodu</th>
                            <th scope="col" class="py-2" style="width: 100px;">Tür</th>
                            <th scope="col" class="py-2">Stok Adı</th>
                            <th scope="col" class="text-end py-2" style="width: 180px;">Varsayılan Üretim Miktarı</th>
                            <th scope="col" class="py-2 text-center" style="width: 90px;">Birim</th>
                            <th scope="col" class="text-center py-2" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="clickable-row" ondblclick="openRecipeDetail('@item.MainProductCode')" style="cursor: pointer;">
                                <td class="fw-bold text-dark"><i class="bi bi-file-earmark-text text-secondary me-2"></i>@item.MainProductCode</td>

                                @{
                                    string badgeColor = "bg-secondary";
                                    if (item.ProductType == "MM") badgeColor = "bg-success";
                                    else if (item.ProductType == "YM") badgeColor = "bg-warning text-dark";
                                    else if (item.ProductType == "HM") badgeColor = "bg-info text-dark";
                                    else if (item.ProductType == "TM") badgeColor = "bg-primary";
                                }
                                <td><span class="badge @badgeColor">@(string.IsNullOrEmpty(item.ProductType) ? "--" : item.ProductType)</span></td>

                                <td class="text-secondary fw-semibold">@item.MainProductName</td>
                                <td class="text-end fw-bold text-success">@item.MainQuantity.ToString("N2")</td>
                                <td class="text-center"><span class="badge bg-light text-dark border">@item.MainUnit</span></td>

                                <td class="text-center" onclick="event.stopPropagation();">
                                    <a href="/Bom/RecipeManagement?productCode=@System.Net.WebUtility.UrlEncode(item.MainProductCode)&mode=view" class="btn btn-xs btn-outline-info fw-semibold py-0 px-2 me-1" style="font-size:0.75rem;">
                                        <i class="bi bi-eye"></i> İncele
                                    </a>
                                    <a href="/Bom/RecipeManagement?productCode=@System.Net.WebUtility.UrlEncode(item.MainProductCode)&mode=edit" class="btn btn-xs btn-outline-warning fw-semibold py-0 px-2" style="font-size:0.75rem;">
                                        <i class="bi bi-pencil"></i> Değiştir
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="erp-footer-bar d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 mt-2 pt-2 border-top">
                <div class="small text-muted font-monospace text-center text-md-start w-100 w-md-auto">
                    <span>Toplam <strong>@Model.TotalCount</strong> kayıt. Sayfa <strong>@Model.CurrentPage</strong> / <strong>@Model.TotalPages</strong></span>
                </div>

                <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-end gap-2 w-100 w-md-auto">
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm m-0">
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="/Bom/RecipeList?productCode=@Context.Request.Query["productCode"]&page=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize"><i class="bi bi-chevron-left"></i></a>
                                </li>
                                @if (Model.CurrentPage > 3)
                                {
                                    <li class="page-item"><a class="page-link font-monospace" href="/Bom/RecipeList?productCode=@Context.Request.Query["productCode"]&page=1&pageSize=@Model.PageSize">1</a></li>
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                }
                                @{
                                    int baslangicSayfasi = Math.Max(1, Model.CurrentPage - 2);
                                    int bitisSayfasi = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                                }
                                @for (int i = baslangicSayfasi; i <= bitisSayfasi; i++)
                                {
                                    <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                        <a class="page-link font-monospace" href="/Bom/RecipeList?productCode=@Context.Request.Query["productCode"]&page=@i&pageSize=@Model.PageSize">@i</a>
                                    </li>
                                }
                                @if (Model.CurrentPage < Model.TotalPages - 2)
                                {
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                    <li class="page-item"><a class="page-link font-monospace" href="/Bom/RecipeList?productCode=@Context.Request.Query["productCode"]&page=@Model.TotalPages&pageSize=@Model.PageSize">@Model.TotalPages</a></li>
                                }
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="/Bom/RecipeList?productCode=@Context.Request.Query["productCode"]&page=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize"><i class="bi bi-chevron-right"></i></a>
                                </li>
                            </ul>
                        </nav>
                        <div class="input-group input-group-sm" style="width: 110px;">
                            <input type="number" id="manualPageInput" class="form-control text-center font-monospace" min="1" max="@Model.TotalPages" value="@Model.CurrentPage" placeholder="No..." onkeypress="if(event.key === 'Enter') jumpToManualPage();" />
                            <button class="btn btn-dark" type="button" onclick="jumpToManualPage()">Git</button>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="border rounded-1 p-5 text-center bg-white my-2">
                <i class="bi bi-folder-x text-muted display-6 d-block mb-2"></i>
                <h6 class="fw-bold text-secondary">Listelenecek Uygun Kayıt Bulunamadı</h6>
                <p class="text-muted small mb-3">Seçilen kriterlere uyan aktif bir Logo stok kartı veya reçete bağlantısı mevcut değil.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function openRecipeDetail(productCode) {
            if (productCode) {
                window.location.href = '/Bom/RecipeManagement?productCode=' + encodeURIComponent(productCode) + '&mode=view';
            }
        }

        function jumpToManualPage() {
            const input = document.getElementById('manualPageInput');
            if (!input) return;
            const pageNo = parseInt(input.value);
            const maxPage = parseInt(input.getAttribute('max'));

            if (!isNaN(pageNo) && pageNo >= 1 && pageNo <= maxPage) {
                window.location.href = '/Bom/RecipeList?productCode=' + encodeURIComponent('@Context.Request.Query["productCode"]') + '&page=' + pageNo + '&pageSize=' + '@(Model?.PageSize ?? 20)';
            } else {
                alert('Lütfen 1 ile ' + (maxPage || 1) + ' arasında geçerli bir sayfa numarası giriniz');
                input.value = '@(Model?.CurrentPage ?? 1)';
            }
        }
    </script>
    <script src="/bom/js/Index.js"></script>
}