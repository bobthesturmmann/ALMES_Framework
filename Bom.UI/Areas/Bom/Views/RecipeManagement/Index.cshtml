@{
    ViewData["Title"] = "Reçete Yönetimi";
    Layout = "~/Areas/Bom/Views/Shared/_BomLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, .15);
        }

        .sticky-top {
            top: -1px;
            z-index: 1020;
        }
    </style>
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-1 mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex align-items-center justify-content-between">
            <h5 class="fw-bold text-dark m-0">
                <i class="bi bi-gear-wide-connected text-primary me-2"></i>Reçete Ekleme & Düzenleme Paneli
            </h5>
            <span class="badge bg-success font-monospace fw-semibold">Demo Sürüm (İşlem Tipi: 1)</span>
        </div>

        <div class="card-body p-4 bg-white">
            <div class="bg-light p-3 rounded-2 border mb-4">
                <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-bookmark-star-fill me-2 text-warning"></i>1. Ana Ürün (Reçete Sahibi)</h6>
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-semibold text-muted">Ana Ürün Kodu / Adı</label>
                        <div class="input-group">
                            <input type="text" id="txtMainProductCode" class="form-control bg-white text-dark fw-bold" placeholder="Ürün Seçiniz..." readonly>
                            <input type="hidden" id="hdnMainProductRef" value="0"> <button class="btn btn-outline-primary" type="button" id="btnSelectMainProduct">
                            <i class="bi bi-box-seam me-1"></i> Seç
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-muted">Üretim Miktarı</label>
                    <input type="number" id="numMainQuantity" class="form-control" value="1.000000" step="1" min="0.000001">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-muted">Üretim Birimi</label>
                    <input type="text" id="txtMainUnit" class="form-control bg-white" placeholder="Birim" readonly>
                    <input type="hidden" id="hdnMainUnitRef" value="1">
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-dark w-100 fw-semibold" id="btnClearForm">
                        <i class="bi bi-trash me-1"></i> Formu Temizle
                    </button>
                </div>
            </div>
        </div>

        <div class="border rounded-2 p-3">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="fw-bold text-secondary m-0"><i class="bi bi-list-nested me-2 text-primary"></i>2. Reçete Bileşenleri (Alt Ürünler)</h6>
                <button type="button" class="btn btn-sm btn-primary fw-semibold" id="btnAddSubProduct" disabled>
                    <i class="bi bi-plus-circle me-1"></i> Bileşen (Alt Ürün) Ekle
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle m-0" id="tblRecipeLines">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 8%">Satır No</th>
                            <th style="width: 20%">Bileşen Kodu</th>
                            <th style="width: 30%">Bileşen Adı</th>
                            <th style="width: 15%">Miktar</th>
                            <th style="width: 12%">Birim</th>
                            <th style="width: 15%" class="text-center">Durum / Aksiyon</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr id="trEmptyRow">
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-arrow-up-circle me-1"></i> Lütfen önce yukarıdan bir <b>Ana Ürün</b> seçiniz.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

@await Html.PartialAsync("_ProductSelectModalPartial")

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            let targetSelection = "";
            let currentLineCount = 0;

            $("#btnSelectMainProduct").on("click", function (e) {
                e.preventDefault();
                targetSelection = "main";
                $("#productSelectModalLabel").html('<i class="bi bi-box-seam text-primary me-2"></i>Ana Ürün Seçimi');
                
                var myModal = new bootstrap.Modal(document.getElementById('productSelectModal'));
                myModal.show();
            });

            $("#btnAddSubProduct").on("click", function (e) {
                e.preventDefault();
                targetSelection = "sub";
                $("#productSelectModalLabel").html('<i class="bi bi-layers text-success me-2"></i>Bileşen (Alt Ürün) Seçimi');
                
                var myModal = new bootstrap.Modal(document.getElementById('productSelectModal'));
                myModal.show();
            });

            $("#btnModalSearch").click(function () {
                let searchTxt = $("#modalSearchInput").val();
                let $tbody = $("#modalProductTable tbody");
    
                $tbody.html('<tr><td colspan="4" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Logo veritabanında filtresiz aranıyor...</td></tr>');

                $.ajax({
                    url: '/Bom/RecipeManagement/SearchProducts',
                    type: 'GET',
                    data: { searchCode: searchTxt, selectionType: targetSelection }, 
                    success: function (res) {
                        if (res.isSuccess && res.data.length > 0) {
                            $tbody.empty();
                            res.data.forEach(function (item) {
                                let row = `<tr>
                                    <td class="fw-bold">${item.productCode}</td>
                                    <td>${item.productName}</td>
                                    <td><span class="badge bg-secondary">${item.unit}</span></td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-success btn-pick" 
                                                data-code="${item.productCode}" 
                                                data-name="${item.productName}" 
                                                data-unit="${item.unit}"
                                                data-idref="${item.productRef}"
                                                data-uref="${item.unitRef}">
                                            <i class="bi bi-check2"></i> Seç
                                        </button>
                                    </td>
                                </tr>`;
                                $tbody.append(row);
                            });
                        } else {
                            $tbody.html('<tr><td colspan="4" class="text-center text-danger py-4"><i class="bi bi-exclamation-triangle"></i> Uygun malzeme kartı bulunamadı!</td></tr>');
                        }
                    },
                    error: function () {
                        $tbody.html('<tr><td colspan="4" class="text-center text-danger py-4">Sistem haberleşme hatası!</td></tr>');
                    }
                });
            });

            $("#modalSearchInput").keypress(function (e) {
                if (e.which == 13) { $("#btnModalSearch").click(); }
            });

            $(document).on("click", ".btn-pick", function () {
                let code = $(this).attr("data-code");
                let name = $(this).attr("data-name");
                let unit = $(this).attr("data-unit");
                let ref = parseInt($(this).attr("data-idref")) || 0;
                let unitref = parseInt($(this).attr("data-uref")) || 1;

                if (targetSelection === "main") {
                    $("#txtMainProductCode").val(code + " - " + name);
                    $("#hdnMainProductRef").val(ref);
                    $("#txtMainUnit").val(unit);
                    $("#hdnMainUnitRef").val(unitref);
                    
                    $("#btnAddSubProduct").prop("disabled", false);
                    $("#trEmptyRow td").html('<i class="bi bi-info-circle me-1"></i> Reçete satırı bulunamadı. Sağ üstten <b>Bileşen Ekle</b> diyerek başlayabilirsiniz.');
                } 
                else if (targetSelection === "sub") {
                    currentLineCount++;
                    $("#trEmptyRow").hide();

                    let uniqueId = "row_" + currentLineCount;
                    let newRow = `<tr id="${uniqueId}">
                        <td class="font-monospace fw-bold text-center">${currentLineCount}</td>
                        <td class="fw-bold text-secondary">${code}</td>
                        <td>${name}</td>
                        <td>
                            <input type="number" class="form-control form-control-sm txt-sub-qty" value="1.000000" step="any" style="max-width:120px;">
                        </td>
                        <td><span class="badge bg-light text-dark border">${unit}</span></td>
                        <td class="text-center bg-status">
                            <button class="btn btn-sm btn-primary btn-save-line fw-semibold" 
                                    data-line="${currentLineCount}"
                                    data-subref="${ref}"
                                    data-subunitref="${unitref}">
                                <i class="bi bi-cloud-arrow-up"></i> Kaydet
                            </button>
                        </td>
                    </tr>`;
                    
                    $("#tblRecipeLines tbody").append(newRow);
                }

                var modalElement = document.getElementById('productSelectModal');
                var modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) { modalInstance.hide(); }

                $("#modalSearchInput").val("");
                $("#modalProductTable tbody").html('<tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-info-circle me-1"></i> Arama yapmak için yukarıdaki kutuyu kullanın.</td></tr>');
            });

            $(document).on("click", ".btn-save-line", function () {
                let $btn = $(this);
                let $tr = $btn.closest("tr");
                
                let payload = {
                    firmaNo: "", 
                    donemNo: "",
                    islemTipi: 1, 
                    satirNo: parseInt($btn.attr("data-line")),
                    anaUrunRef: parseInt($("#hdnMainProductRef").val()),
                    anaMiktar: parseFloat($("#numMainQuantity").val()),
                    anaBirimRef: parseInt($("#hdnMainUnitRef").val()),
                    altUrunRef: parseInt($btn.attr("data-subref")),
                    altMiktar: parseFloat($tr.find(".txt-sub-qty").val()),
                    altBirimRef: parseInt($btn.attr("data-subunitref")),
                    lostFactor: 0.0
                };

                $btn.prop("disabled", true).html('<span class="spinner-border spinner-border-sm"></span>');

                $.ajax({
                    url: '/Bom/RecipeManagement/SaveLine',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function (res) {
                        if (res.isSuccess) {
                            $tr.find(".txt-sub-qty").prop("disabled", true);
                            $tr.addClass("table-success");
                            $tr.find(".bg-status").html('<span class="badge bg-success py-2 px-3 fw-bold shadow-sm"><i class="bi bi-check-circle-fill me-1"></i> Logo\'ya İşlendi</span>');
                        } else {
                            alert("Hata: " + res.message);
                            $btn.prop("disabled", false).html('<i class="bi bi-cloud-arrow-up"></i> Yeniden Dene');
                        }
                    },
                    error: function () {
                        alert("Sunucuyla haberleşirken bir hata oluştu!");
                        $btn.prop("disabled", false).html('<i class="bi bi-cloud-arrow-up"></i> Yeniden Dene');
                    }
                });
            });

            $("#btnClearForm").click(function () {
                if(confirm("Tüm formu sıfırlamak istediğinize emin misiniz?")) {
                    location.reload();
                }
            });
        });
    </script>
}