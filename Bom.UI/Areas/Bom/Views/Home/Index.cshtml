@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Bom/Views/Shared/_BomLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
    <div class="d-flex align-items-center">
        <div class="bg-dark text-white rounded-2 p-3 me-3 shadow-sm">
            <i class="bi bi-diagram-3-fill fs-3"></i>
        </div>
        <div>
            <h4 class="fw-bold m-0 text-dark">BOM — Ürün Reçeteleri Yönetim Sistemi</h4>
            <span class="text-muted small font-monospace">ALMES Çatısı Çekirdek Modülü</span>
        </div>
    </div>
    <div>
        <span class="badge bg-success px-3 py-2 rounded-1 fw-semibold shadow-sm">Modül Aktif</span>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-6">
        <div class="card h-100 border-0 shadow-sm rounded-1 p-4 bg-white hover-card">
            <div class="mb-3 text-success"><i class="bi bi-calculator fs-2"></i></div>
            <h5 class="fw-bold text-dark">Reçete Listesi & Maliyet Simülasyonu</h5>
            <p class="text-muted small mb-4">Logo ERP'den gelen aktif Mamul/Yarı Mamul kartlarını inceleyin, çift tıklayarak üretim ağaçlarına girin ve bu ağaçlar üzerinden dinamik maliyet simülasyonlarını çalıştırın.</p>
            <div class="mt-auto">
                <a href="/Bom/RecipeList" class="btn btn-success btn-sm fw-semibold px-4 rounded-1 w-100 py-2 shadow-sm">
                    <i class="bi bi-arrow-right-circle me-1"></i> Listeyi Aç
                </a>
            </div>
        </div>
    </div>
</div>