@model Bom.Lib.PagedBomResult

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ALMES ERP - Stok Reçete Yönetimi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/bom/css/bom-style.css">
</head>
<body>

    <div class="container-fluid py-4 px-4">
        <div class="erp-box">

            <div class="erp-header p-3 d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="fw-bold m-0">
                        <i class="bi bi-box-seam-fill me-2"></i>
                        @(ViewBag.ActiveMode == 2 ? "📊 Üretim Ağacı (Reçete) Detay Görünümü" : "🏭 Tanımlı Stok Kartları Listesi (Mamul / Yarı Mamul)")
                    </h5>
                </div>
                <div>
                    @if (ViewBag.ActiveMode == 2)
                    {
                        <a href="@ViewBag.ReturnUrl" class="btn btn-sm btn-outline-light me-2 fw-semibold"><i class="bi bi-arrow-left me-1"></i> Kart Listesine Dön</a>
                    }
                    <span class="badge bg-secondary font-monospace">v0.0.20</span>
                </div>
            </div>

            <div class="p-3">

                @if (ViewBag.ActiveMode == 2)
                {
                    <div class="card mb-3 border-primary-subtle bg-light-subtle rounded-1">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="fw-bold text-primary m-0"><i class="bi bi-info-circle-fill me-1"></i> Ana Ürün / Reçete Sahibi Bilgileri</h6>
                                <a href="@ViewBag.ReturnUrl" class="text-primary small text-decoration-none fw-semibold"><i class="bi bi-chevron-left"></i> Listeye Geri Dön</a>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <span class="text-muted small d-block">Ana Ürün Kodu:</span>
                                    <strong class="text-dark fs-5">@ViewBag.MainProductCode</strong>
                                </div>
                                <div class="col-md-5">
                                    <span class="text-muted small d-block">Ana Ürün Adı:</span>
                                    <strong class="text-dark">@ViewBag.MainProductName</strong>
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <span class="text-muted small d-block">Varsayılan Üretim Miktarı:</span>
                                    <strong class="text-success fs-5">@(((decimal)(ViewBag.MainQuantity ?? 0m)).ToString("N2"))</strong>
                                    <span class="badge bg-secondary">@ViewBag.MainUnit</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary p-2 mb-3 rounded-1 d-flex align-items-center border" role="alert">
                        <i class="bi bi-info-circle-fill text-dark fs-5 me-2"></i>
                        <div class="small text-dark">
                            Reçetesi olan aktif Mamul and Yarı Mamul listesidir. Detayını görmek istediğiniz kartın üzerine <strong>çift tıklayınız.</strong>
                        </div>
                    </div>

                    <div class="p-3 mb-3 bg-light rounded-1 border">
                        <form method="get" action="/Bom" id="searchForm" class="row g-2 align-items-center">
                            <input type="hidden" name="page" value="1" />

                            <div class="col-12 col-md-6">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                                    <input type="text" name="productCode" class="form-control border-start-0 ps-0" placeholder="Ürün Kodu Sorgula... (Örn: M-001)" value="@Context.Request.Query["productCode"]" />
                                </div>
                            </div>

                            <div class="col-6 col-md-2">
                                <select name="pageSize" class="form-select form-select-sm" onchange="document.getElementById('searchForm').submit();">
                                    <!option value="10" @(ViewBag.PageSize == 10 ? "selected" : "")>10 Kayıt</!option>
                                    <!option value="20" @(ViewBag.PageSize == 20 ? "selected" : "")>20 Kayıt</!option>
                                    <!option value="50" @(ViewBag.PageSize == 50 ? "selected" : "")>50 Kayıt</!option>
                                    <!option value="100" @(ViewBag.PageSize == 100 ? "selected" : "")>100 Kayıt</!option>
                                </select>
                            </div>

                            <div class="col-6 col-md-2">
                                <button type="submit" class="btn btn-dark btn-sm w-100 fw-semibold">
                                    <i class="bi bi-funnel-fill me-1"></i> Query
                                </button>
                            </div>

                            <div class="col-12 col-md-2">
                                <a href="/Bom" class="btn btn-outline-secondary btn-sm w-100 fw-semibold">
                                    <i class="bi bi-arrow-clockwise"></i> Temizle
                                </a>
                            </div>
                        </form>
                    </div>
                }

                @if (Model != null && Model.Items.Any())
                {
                    <div class="table-responsive border rounded-1">
                        <table class="table table-sm table-flat align-middle m-0">
                            <thead>
                                <tr>
                                    @if (ViewBag.ActiveMode == 2)
                                    {
                                        <th scope="col" class="text-center py-2" style="width: 70px;">Satır No</th>
                                        <th scope="col" class="py-2 text-primary">Alt Bileşen Kodu</th>
                                        <th scope="col" class="py-2 text-primary">Alt Bileşen Adı</th>
                                        <th scope="col" class="text-end py-2 text-primary" style="width: 150px;">İhtiyaç Miktarı</th>
                                        <th scope="col" class="py-2 text-primary" style="width: 100px;">Birim</th>
                                    }
                                    else
                                    {
                                        <th scope="col" class="text-center py-2" style="width: 70px;">S.No</th>
                                        <th scope="col" class="py-2">Ürün / Stok Kodu</th>
                                        <th scope="col" class="py-2">Stok Adı</th>
                                        <th scope="col" class="text-end py-2" style="width: 200px;">Varsayılan Üretim Miktarı</th>
                                        <th scope="col" class="py-2" style="width: 100px;">Birim</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int siraNo = ((Model.CurrentPage - 1) * Model.PageSize) + 1;
                                }
                                @foreach (var item in Model.Items)
                                {
                                    @if (ViewBag.ActiveMode == 2)
                                    {
                                        <tr>
                                            <td class="text-center font-monospace text-muted">@item.LineNo</td>
                                            <td class="fw-bold text-primary">@item.SubProductCode</td>
                                            <td class="text-dark small">@item.SubProductName</td>
                                            <td class="text-end fw-bold text-primary">@item.SubQuantity.ToString("N2")</td>
                                            <td><span class="badge bg-light text-primary border border-primary-subtle">@item.SubUnit</span></td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr class="clickable-row position-relative" ondblclick="openRecipeDetail('@item.MainProductCode')" data-product-code="@item.MainProductCode" style="cursor: pointer;">
                                            <td class="text-center font-monospace text-muted">@siraNo</td>
                                            <td class="fw-bold text-dark">
                                                <i class="bi bi-file-earmark-text text-secondary me-2"></i>@item.MainProductCode
                                            </td>
                                            <td class="text-secondary fw-semibold">
                                                @item.MainProductName
                                                <span class="d-inline d-md-none text-primary float-end small"><i class="bi bi-chevron-right"></i></span>
                                            </td>
                                            <td class="text-end fw-bold text-success">@item.MainQuantity.ToString("N2")</td>
                                            <td><span class="badge bg-light text-dark border">@item.MainUnit</span></td>
                                        </tr>
                                    }
                                    siraNo++;
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="erp-footer-bar d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 mt-2 pt-2 border-top">

                        <div class="small text-muted font-monospace text-center text-md-start w-100 w-md-auto">
                            @if (ViewBag.ActiveMode == 2)
                            {
                                <span>Bu reçeteye ait toplam <strong>@Model.Items.Count</strong> satır listelendi.</span>
                            }
                            else
                            {
                                <span>Toplam <strong>@Model.TotalCount</strong> kayıt. Sayfa <strong>@Model.CurrentPage</strong> / <strong>@Model.TotalPages</strong></span>
                            }
                        </div>

                        <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-end gap-2 w-100 w-md-auto">
                            @if (ViewBag.ActiveMode == 2)
                            {
                                <a href="@ViewBag.ReturnUrl" class="btn btn-sm btn-dark fw-semibold px-3"><i class="bi bi-arrow-left me-1"></i> Listeye Geri Dön</a>
                            }
                            else if (Model.TotalPages > 1)
                            {
                                <nav aria-label="Page navigation">
                                    <ul class="pagination pagination-sm m-0">
                                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                            <a class="page-link" href="/Bom?productCode=@Context.Request.Query["productCode"]&page=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize"><i class="bi bi-chevron-left"></i></a>
                                        </li>

                                        @if (Model.CurrentPage > 3)
                                        {
                                            <li class="page-item"><a class="page-link font-monospace" href="/Bom?productCode=@Context.Request.Query["productCode"]&page=1&pageSize=@Model.PageSize">1</a></li>
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                        }

                                        @{
                                            int baslangicSayfasi = Math.Max(1, Model.CurrentPage - 2);
                                            int bitisSayfasi = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                                        }

                                        @for (int i = baslangicSayfasi; i <= bitisSayfasi; i++)
                                        {
                                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                                <a class="page-link font-monospace" href="/Bom?productCode=@Context.Request.Query["productCode"]&page=@i&pageSize=@Model.PageSize">@i</a>
                                            </li>
                                        }

                                        @if (Model.CurrentPage < Model.TotalPages - 2)
                                        {
                                            <li class="page-item disabled"><span class="page-link">...</span></li>
                                            <li class="page-item"><a class="page-link font-monospace" href="/Bom?productCode=@Context.Request.Query["productCode"]&page=@Model.TotalPages&pageSize=@Model.PageSize">@Model.TotalPages</a></li>
                                        }

                                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                            <a class="page-link" href="/Bom?productCode=@Context.Request.Query["productCode"]&page=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize"><i class="bi bi-chevron-right"></i></a>
                                        </li>
                                    </ul>
                                </nav>

                                <div class="input-group input-group-sm" style="width: 110px;">
                                    <input type="number" id="manualPageInput" class="form-control text-center font-monospace"
                                           min="1" max="@Model.TotalPages" value="@Model.CurrentPage" placeholder="No..."
                                           onkeypress="if(event.key === 'Enter') jumpToManualPage();" />
                                    <button class="btn btn-dark" type="button" onclick="jumpToManualPage()">
                                        Git
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="border rounded-1 p-5 text-center bg-white my-2">
                        <i class="bi bi-folder-x text-muted display-6 d-block mb-2"></i>
                        <h6 class="fw-bold text-secondary">Listelenecek Uygun Kayıt Bulunamadı</h6>
                        <p class="text-muted small mb-3">Seçilen kriterlere uyan aktif bir Logo stok kartı veya reçete bağlantısı mevcut değil.</p>
                        @if (ViewBag.ActiveMode == 2)
                        {
                            <a href="@ViewBag.ReturnUrl" class="btn btn-sm btn-dark fw-semibold"><i class="bi bi-arrow-left me-1"></i> Listeye Geri Dön</a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
                        function openRecipeDetail(productCode) {
                if (productCode) {
                    window.location.href = '/Bom?productCode=' + encodeURIComponent(productCode) + '&isDetail=true';
                }
            }

            function jumpToManualPage() {
                const input = document.getElementById('manualPageInput');
                const pageNo = parseInt(input.value);
                const maxPage = parseInt(input.getAttribute('max'));

                if (pageNo >= 1 && pageNo <= maxPage) {
                    window.location.href = '/Bom?productCode=' + encodeURIComponent('@Context.Request.Query["productCode"]') + '&page=' + pageNo + '&pageSize=' + '@Model.PageSize';
                } else {
                    alert('Lütfen 1 ile ' + maxPage + ' arasında geçerli bir sayfa numarası giriniz');
                    input.value = '@Model.CurrentPage';
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

                if (isTouchDevice) {
                    const rows = document.querySelectorAll('.clickable-row');
                    rows.forEach(row => {
                        row.addEventListener('click', function () {
                            const productCode = this.getAttribute('data-product-code');
                            openRecipeDetail(productCode);
                        });
                    });
                }
            });
    </script>
    <script src="/bom/js/Index.js"></script>
</body>
</html>