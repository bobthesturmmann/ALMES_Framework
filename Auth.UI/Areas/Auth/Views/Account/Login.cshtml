@model Auth.UI.Areas.Auth.Models.LoginViewModel

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Almes Portal - Giriş</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/auth/css/login.css" />
</head>
<body>

    <div class="login-card p-0 m-3">
        <div class="login-header">
            <h2>ALMES PORTAL</h2>
            <p class="text-white-50 small mb-0">Kurumsal Yönetim Sistemi Girişi</p>
        </div>

        <div class="card-body p-4 pt-5">
            <form asp-area="Auth" asp-controller="Account" asp-action="Login" method="post">
                <input type="hidden" name="ReturnUrl" value="@Model?.ReturnUrl" />

                <div class="mb-4">
                    <label for="Username" class="form-label small fw-bold text-secondary">Kullanıcı Adı</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                        <input type="text" id="Username" name="Username" class="form-control form-control-lg fs-6"
                               value="@Model?.Username" placeholder="Kullanıcı adınızı girin" required autocomplete="off" />
                    </div>
                </div>

                <div class="mb-4">
                    <label for="Password" class="form-label small fw-bold text-secondary">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" id="Password" name="Password" class="form-control form-control-lg fs-6"
                               placeholder="••••••••" required />
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe">
                        <label class="form-check-input-label small text-muted" for="rememberMe">Beni Hatırla</label>
                    </div>
                    <a href="#" class="small text-decoration-none text-primary fw-semibold">Şifremi Unuttum</a>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-login btn-lg fs-6 rounded-3 text-white">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                    </button>
                </div>
            </form>
        </div>

        <div class="card-footer bg-light border-0 text-center py-3">
            <span class="text-muted small">Infrastructure Status: <strong class="text-success">v0.0.24</strong></span>
        </div>
    </div>

    <script src="/auth/js/login.js"></script>
</body>
</html>