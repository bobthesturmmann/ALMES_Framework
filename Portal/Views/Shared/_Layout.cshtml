@model dynamic

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Almes Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Portal.styles.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-dark" asp-area="" asp-controller="Portal" asp-action="Index">
                    Almes Portal
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-secondary" asp-area="" asp-controller="Portal" asp-action="Index">
                                Ana Sayfa
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span class="text-muted small me-3 font-monospace">@User.Identity.Name</span>
                            <a href="/Auth/Account/Logout" class="btn btn-sm btn-outline-danger fw-semibold">
                                <i class="bi bi-box-arrow-right me-1"></i> Çıkış Yap
                            </a>
                        }
                        else
                        {
                            <a href="/Auth/Account/Login" class="btn btn-sm btn-outline-dark fw-semibold">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Giriş Yap
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-2 mt-auto">
        <div class="container-fluid px-4 d-flex align-items-center justify-content-between small">
            <div>
                &copy; 2026 - <strong>Almes Portal</strong>
            </div>
            <div class="text-end text-muted font-monospace" style="font-size: 12px;">
                test
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>