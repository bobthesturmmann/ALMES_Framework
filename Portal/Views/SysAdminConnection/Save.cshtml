@model _Core.Shared.Lib.SysConnectionModel
@{
    ViewData["Title"] = Model.Id > 0 ? "Bağlantı Düzenle" : "Yeni Bağlantı Tanımla";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-save me-2"></i> @(Model.Id > 0 ? "Mevcut Bağlantı Ayarlarını Güncelle" : "Yeni Dinamik Modül Bağlantısı")</h5>
        </div>
        <div class="card-body">
            <form asp-action="Save" asp-controller="SysAdminConnection" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label font-weight-bold">Modül Seçimi</label>
                        <select asp-for="ModuleName" class="form-select" required>
                            <option value="BOM">BOM (Reçete)</option>
                            <option value="AUTH">AUTH (Güvenlik)</option>
                            <option value="FINANS">FINANS</option>
                            <option value="STOK">STOK</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Firma No</label>
                        <input asp-for="FirmaNo" type="text" class="form-control" placeholder="Örn: 001" required maxlength="10" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Dönem / Yıl</label>
                        <input asp-for="DonemNo" type="text" class="form-control" placeholder="Örn: 2026" required maxlength="10" />
                    </div>

                    <div class="col-12">
                        <label class="form-label d-flex justify-content-between">
                            <span>Özel Bağlantı Cümlesi (ConnectionString)</span>
                            <span class="text-muted small">*İsteğe Bağlı</span>
                        </label>
                        <textarea asp-for="ConnectionString" class="form-control" rows="3"
                                  placeholder="Server=192.168... (Eğer boş bırakırsanız ortak sunucu şablonu üzerinden otomatik database adı üretilir)"></textarea>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("Index", "SysAdminConnection")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> İptal / Listeye Dön
                    </a>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fas fa-check me-1"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>