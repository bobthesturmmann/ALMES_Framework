@model Portal.Models.SysAdminViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ALMES - Sistem Yönetim Kokpiti</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
            .form-switch .form-check-input {
                width: 2.5em;
                height: 1.25em;
                cursor: pointer;
            }

                .form-switch .form-check-input:checked {
                    background-color: #198754;
                    border-color: #198754;
                }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">

        <div class="card shadow-sm border-0 rounded-3 mb-4 bg-dark text-white">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-warning"><i class="fas fa-sliders-h me-2"></i>Global AppSettings Parametreleri</h5>
                <form asp-controller="SysAdminConnection" asp-action="SaveGlobalSettings" method="post" class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small text-muted">Şirket Kodu</label>
                        <input type="text" name="globalSirketKodu" value="@Model.GlobalSirketKodu" class="form-control bg-secondary text-white border-0" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted">Dönem Kodu</label>
                        <input type="text" name="globalDonemKodu" value="@Model.GlobalDonemKodu" class="form-control bg-secondary text-white border-0" required />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted">Varsayılan Ana Anahtar (DefaultConnection)</label>
                        <input type="text" name="globalConnectionString" value="@Model.GlobalConnectionString" class="form-control bg-secondary text-white border-0 small" required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-warning w-100 fw-bold"><i class="fas fa-save me-1"></i> Global Ayarları Güncelle</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-3 mb-4 bg-white border-start border-success border-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-2 text-success"><i class="fas fa-eye me-2"></i>Portal Ana Sayfa Görünürlük Ayarları (Şifreli ShownModules)</h5>
                <p class="text-muted small mb-4">Burada açık olan modüller ana sayfada buton olarak listelenir. Arka planda MD5 hash'e dönüştürülerek güvenle saklanır.</p>

                <form asp-controller="SysAdminConnection" asp-action="SaveShownModules" method="post">
                    <div class="d-flex flex-wrap gap-5 align-items-center mb-3">
                        @for (int i = 0; i < Model.ActiveModules.Count; i++)
                        {
                            var moduleName = Model.ActiveModules[i].ToUpper();
                            bool isShown = Model.ShownModules.Contains(moduleName);

                            <div class="form-check form-switch d-flex align-items-center gap-2">
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedShownModules"
                                       value="@moduleName"
                                       id="switch_@moduleName"
                                @(isShown ? "checked" : "") />
                                <label class="form-check-label fw-bold text-dark fs-6" for="switch_@moduleName">
                                    @moduleName Modülü
                                </label>
                            </div>
                        }

                        <div class="ms-auto">
                            <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
                                <i class="fas fa-sync-alt me-1"></i> Görünürlük Ayarlarını Kaydet
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
                    <h5 class="fw-bold text-primary mb-4"><i class="fas fa-network-wired me-2"></i>Bağlantı Detayı</h5>
                    <form asp-controller="SysAdminConnection" asp-action="SaveConnection" method="post">
                        <input type="hidden" name="CurrentModel.Id" value="@Model.CurrentModel.Id" />

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Modül Seçimi (Dinamik)</label>
                            <select asp-for="CurrentModel.ModuleName" class="form-select" required>
                                <option value="">-- Modül Seçiniz --</option>
                                @foreach (var module in Model.ActiveModules)
                                {
                                    if (Model.CurrentModel != null && module.Equals(Model.CurrentModel.ModuleName, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@module.ToUpper()" selected="selected">@module.ToUpper()</option>
                                    }
                                    else
                                    {
                                        <option value="@module.ToUpper()">@module.ToUpper()</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Özel Şirket Kodu (FirmaNo)</label>
                            <input type="text" asp-for="CurrentModel.FirmaNo" class="form-control" placeholder="Boş bırakılırsa global ayarı ezer" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Özel Dönem Kodu (DonemNo)</label>
                            <input type="text" asp-for="CurrentModel.DonemNo" class="form-control" placeholder="Boş bırakılırsa global ayarı ezer" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Özel Connection String</label>
                            <textarea asp-for="CurrentModel.ConnectionString" class="form-control" rows="3" placeholder="Farklı SQL Instance bağlamak için doldurun"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">
                            @(Model.CurrentModel.Id > 0 ? "Değişiklikleri Kaydet" : "Matrise Yeni Satır Ekle")
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
                    <h5 class="fw-bold text-secondary mb-4"><i class="fas fa-list me-2"></i>Bağlantı Matrisi Dağılımı</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Modül</th>
                                    <th>Firma</th>
                                    <th>Dönem</th>
                                    <th>Özel Bağlantı</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.SavedConnections)
                                {
                                    <tr>
                                        <td><span class="badge bg-primary px-2.5 py-1.5 fs-7">@item.ModuleName</span></td>
                                        <td>@(string.IsNullOrEmpty(item.FirmaNo) ? "Global" : item.FirmaNo)</td>
                                        <td>@(string.IsNullOrEmpty(item.DonemNo) ? "Global" : item.DonemNo)</td>
                                        <td class="text-truncate small text-muted" style="max-width: 200px;">
                                            @(string.IsNullOrEmpty(item.ConnectionString) ? "Default Server (ORPASAN)" : item.ConnectionString)
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="SysAdminConnection" asp-action="Index" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="fas fa-edit"></i></a>
                                            <a asp-controller="SysAdminConnection" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')"><i class="fas fa-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</body>
</html>